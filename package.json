{
  "name": "paperclip-docs",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:build": "node docs/docs-website/build-release.mjs --base-path /paperclip-docs/ --out-dir .site",
    "docs:build:auto": "node docs/docs-website/build-release.mjs --base-path auto --out-dir .site",
