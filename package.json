{
  "name": "paperclip-docs",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:build": "node site/build-release.mjs --base-path / --out-dir .site",
    "docs:build:github-subpath": "node site/build-release.mjs --base-path /paperclip-docs/ --out-dir .site",
    "docs:build:auto": "node site/build-release.mjs --base-path auto --out-dir .site",
    "docs:serve": "python3 -m http.server 4321 --directory .site",
    "docs:publish": "npm run docs:publish:cloudflare",
    "docs:publish:cloudflare": "npm run docs:build && wrangler pages deploy .site --project-name paperclip-docs --branch main",
    "docs:publish:github": "./scripts/publish-gh-pages.sh",
    "sync:lint-links": "node scripts/sync/lint-links.mjs",
    "sync:verify-nav": "node scripts/sync/verify-nav.mjs",
    "sync:backfill-screenshots": "node scripts/sync/backfill-screenshots.mjs",
    "sync:compare-window": "node scripts/sync/compare-window.mjs",
    "sync:check-drift": "node scripts/sync/check-drift.mjs",
    "sync:detect-renames": "node scripts/sync/detect-renames.mjs",
    "sync:check": "npm run sync:lint-links && npm run sync:verify-nav && npm run sync:check-drift",
    "sync:test": "node scripts/sync/test.mjs"
  }
}
